#!/bin/sh
# Get the directory where this script lives
DIR="$(dirname "$(readlink -f "$0")")"

# Check for Alpine and prefer musl variant if available
if [ -f /etc/alpine-release ] && [ -f "$DIR/kubectl.musl.toml" ]; then
    "$DIR/.lazybox" trust -y -a -q .
    MISE_LOCKED=0 exec "$DIR/.lazybox" tool-stub "$DIR/kubectl.musl.toml" "$@"
else
    "$DIR/.lazybox" trust -y -a -q .
    MISE_LOCKED=0 exec "$DIR/.lazybox" tool-stub "$DIR/kubectl.toml" "$@"
fi
